generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth (NextAuth) ──────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Multi-Tenancy ────────────────────────────────────────────────────────────

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rooftops Rooftop[]
  users    User[]
}

model Rooftop {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  slug           String   @unique
  // OEM selections stored as JSON array string: e.g. '["GM","Ford"]'
  oems           String   @default("[]")
  // Financial config
  laborRate      Float    @default(125.00)
  taxRate        Float    @default(0.07)
  shopSupplyPct  Float    @default(0.08)
  shopSupplyCap  Float    @default(45.00)
  currency       String   @default("USD")
  timezone       String   @default("America/Chicago")
  // MFA policy: admin can require TOTP for all users on this rooftop
  mfaRequired    Boolean  @default(false)
  // DMS integration
  dmsProvider    String?  // "cdk" | "reynolds" | null
  dmsConfig      String?  @db.Text // encrypted JSON: { clientId, clientSecret, dealerNumber, ... }
  // RO numbering config
  roNumberPrefix     String?  // e.g. "RO-", "WO", "" (empty = numbers only)
  roNumberAlphaGroup String?  @default("") // e.g. "A", "B", "" — inserted between prefix and digits
  roNumberNext    Int      @default(1)   // next sequence number to assign
  roNumberPadding Int      @default(5)   // zero-padding width e.g. 5 → "00042"
  // SMS notifications
  smsEnabled      Boolean  @default(false)
  smsFromNumber   String?
  // Service interval reminders
  serviceRemindersEnabled Boolean @default(false)
  reminderLeadDays        Int     @default(30)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization        Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  users               User[]
  additionalUsers     UserRooftop[]
  repairOrders        RepairOrder[]
  pricingMatrix       PricingMatrix[]
  announcements       Announcement[]
  partInventory       PartInventory[]
  // [FEATURE: core_return_tracking] START
  partReturns         PartReturn[]
  // [FEATURE: core_return_tracking] END
  partRequests        PartRequest[]
  // [FEATURE: notifications] START
  notifications       Notification[]
  // [FEATURE: notifications] END
  // [FEATURE: special_orders] START
  specialOrderParts   SpecialOrderPart[]
  // [FEATURE: special_orders] END
  // [FEATURE: purchase_orders] START
  purchaseOrders      PurchaseOrder[]
  // [FEATURE: purchase_orders] END
  // [FEATURE: warranty_claims] START
  warrantyClaims      WarrantyClaim[]
  // [FEATURE: warranty_claims] END
  // [FEATURE: loaner_vehicles] START
  loanerVehicles      LoanerVehicle[]
  // [FEATURE: loaner_vehicles] END
  techCertifications  TechCertification[]
  // [FEATURE: fleet_accounts] START
  fleetAccounts       FleetAccount[]
  // [FEATURE: fleet_accounts] END
  lotVehicles         LotVehicle[]
  customers           Customer[]
  customerVehicles    CustomerVehicle[]
  partTags            PartTag[]

  @@index([organizationId])
}

model User {
  id             String   @id @default(cuid())
  name           String?
  email          String?  @unique
  emailVerified  DateTime?
  image          String?
  hashedPassword String?
  // role: "admin" | "advisor" | "manager" | "developer" | "technician"
  role           String   @default("advisor")
  organizationId String?
  rooftopId      String?
  employeeId     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization        Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  rooftop             Rooftop?      @relation(fields: [rooftopId], references: [id], onDelete: SetNull)
  accounts            Account[]
  sessions            Session[]
  repairOrders        RepairOrder[]
  roOverrides         ROOverride[]
  auditLogs           AuditLog[]
  mfa                 UserMFA?
  additionalRooftops  UserRooftop[]
  importBatches       ImportBatch[]
  roMessages          ROMessage[]   @relation("UserROMessages")
  roNotes             RONote[]      @relation("UserRONotes")
  announcements       Announcement[] @relation("UserAnnouncements")
  techRepairOrders    RepairOrder[] @relation("TechRepairOrders")
  inventoryMovements  InventoryMovement[]
  // [FEATURE: dvi] START
  dviReports          DVIReport[]   @relation("TechDVIReports")
  // [FEATURE: dvi] END
  // [FEATURE: tech_time_clock] START
  timeEntries         TimeEntry[]   @relation("TechTimeEntries")
  // [FEATURE: tech_time_clock] END
  // [FEATURE: parts_ordering] START
  partsOrders         PartsOrder[]  @relation("UserPartsOrders")
  // [FEATURE: parts_ordering] END
  partRequests            PartRequest[]      @relation("PartRequestsBy")
  // [FEATURE: core_return_tracking] START
  partReturns             PartReturn[]       @relation("UserPartReturns")
  // [FEATURE: core_return_tracking] END
  // [FEATURE: canned_inspections] START
  techInspections         RoInspection[]     @relation("TechInspections")
  // [FEATURE: canned_inspections] END
  // [FEATURE: notifications] START
  notifications           Notification[]
  // [FEATURE: notifications] END
  // [FEATURE: special_orders] START
  specialOrdersCreated    SpecialOrderPart[] @relation("SOPCreatedBy")
  // [FEATURE: special_orders] END
  // [FEATURE: purchase_orders] START
  purchaseOrdersCreated   PurchaseOrder[]    @relation("POCreatedBy")
  // [FEATURE: purchase_orders] END
  // [FEATURE: warranty_claims] START
  warrantyClaims          WarrantyClaim[]    @relation("WarrantyCreatedBy")
  // [FEATURE: warranty_claims] END
  // [FEATURE: loaner_vehicles] START
  loanerLoans             LoanerLoan[]       @relation("LoanerLoanCreatedBy")
  // [FEATURE: loaner_vehicles] END
  techCertifications      TechCertification[]

  @@unique([rooftopId, employeeId])
}

// MFA (TOTP) record — one per user, enabledAt null until first successful verify
model UserMFA {
  id          String    @id @default(cuid())
  userId      String    @unique
  secret      String    // TOTP secret (base32, stored encrypted in prod)
  backupCodes String    @db.Text // JSON array of bcrypt-hashed backup codes
  enabledAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Junction table for users who need access to multiple rooftops within the same org
// User.rooftopId remains the primary/default rooftop; this table holds extras
model UserRooftop {
  id        String   @id @default(cuid())
  userId    String
  rooftopId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  rooftop Rooftop @relation(fields: [rooftopId], references: [id], onDelete: Cascade)

  @@unique([userId, rooftopId])
  @@index([userId])
}

// ─── VIN & Vehicle ────────────────────────────────────────────────────────────

model VehicleCache {
  id          String   @id @default(cuid())
  vin         String   @unique
  make        String
  model       String
  year        Int
  engine      String?
  drivetrain  String?
  trim        String?
  oem         String?
  rawData     String   @db.Text // JSON blob from NHTSA
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  @@index([vin])
}

// ─── OEM Rules ────────────────────────────────────────────────────────────────

// One record per OEM + mileage interval combination
// serviceDefinitions: JSON array of { id, name, category, description, required }
model MaintenanceSchedule {
  id                 String   @id @default(cuid())
  oem                String   // "GM" | "Ford" | ...
  mileageInterval    Int      // e.g. 5000, 7500, 10000, 15000, 30000, 60000
  // JSON: [{ id, name, category, description, isRequired, applicableEngines?, applicableDrivetrains? }]
  serviceDefinitions String   @db.Text
  notes              String?
  // Versioning
  version            Int      @default(1)
  isActive           Boolean  @default(true)
  effectiveDate      DateTime @default(now())
  importBatchId      String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([oem, mileageInterval, version])
  @@index([oem])
  @@index([oem, isActive])
}

// Parts catalog with conditional rules
// conditions: JSON { engines: [], drivetrains: [], trims: [] } — empty = applies to all
model PartsCatalog {
  id           String   @id @default(cuid())
  oem          String
  partNumber   String
  name         String
  description  String?
  defaultCost  Float    @default(0)
  // JSON: conditions for applicability, e.g. { "engines": ["6.2L V8"], "drivetrains": ["RWD"] }
  conditions   String   @default("{}") @db.Text
  // Which services this part applies to (JSON array of service IDs/names)
  serviceIds   String   @default("[]") @db.Text
  quantityRule String   @default("1") // "1", "6" (for quarts), or formula string
  isKit        Boolean  @default(false)
  // If isKit=true, bundled part numbers (JSON array)
  kitParts     String   @default("[]") @db.Text
  // Versioning
  version       Int      @default(1)
  isActive      Boolean  @default(true)
  effectiveDate DateTime @default(now())
  importBatchId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([oem, partNumber, version])
  @@index([oem])
  @@index([oem, isActive])
}

// OEM flat-rate labor operations
model LaborOperation {
  id            String   @id @default(cuid())
  oem           String
  opCode        String
  name          String
  description   String?
  flatRateHours Float
  // JSON: service IDs this op maps to
  serviceIds    String   @default("[]") @db.Text
  conditions    String   @default("{}") @db.Text
  // Versioning
  version       Int      @default(1)
  isActive      Boolean  @default(true)
  effectiveDate DateTime @default(now())
  importBatchId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([oem, opCode, version])
  @@index([oem])
  @@index([oem, isActive])
}

// One-Time Parts Recommendations — non-recurring mileage-triggered upsells
model OTPRRule {
  id               String   @id @default(cuid())
  oem              String
  name             String
  description      String?
  serviceCategory  String
  // Trigger at this mileage (with a ± window applied in code)
  mileageThreshold Int
  // Parts to recommend (JSON array of part numbers)
  partNumbers      String   @default("[]") @db.Text
  // Urgency: "urgent" | "suggested" | "informational"
  urgencyTier      String   @default("suggested")
  conditions       String   @default("{}") @db.Text
  isActive         Boolean  @default(true)
  // Versioning
  version          Int      @default(1)
  effectiveDate    DateTime @default(now())
  importBatchId    String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([oem, mileageThreshold])
  @@index([oem, isActive])
}

// ─── OEM Import Batches ───────────────────────────────────────────────────────

// Tracks each bulk import operation for audit and rollback
model ImportBatch {
  id           String   @id @default(cuid())
  importedById String
  // "MaintenanceSchedule" | "PartsCatalog" | "LaborOperation" | "OTPRRule"
  entityType   String
  recordCount  Int      @default(0)
  newCount     Int      @default(0)   // records that didn't exist before
  updatedCount Int      @default(0)   // records that replaced an existing version
  // "committed" | "rolledBack"
  status       String   @default("committed")
  // JSON array of validation/import errors
  errorLog     String?  @db.Text
  createdAt    DateTime @default(now())

  importedBy User @relation(fields: [importedById], references: [id])

  @@index([importedById])
  @@index([entityType, createdAt])
}

// ─── Pricing ──────────────────────────────────────────────────────────────────

// Per-rooftop tiered parts markup
// tiers: JSON [{ minCost, maxCost, markupPct }], e.g. [{0, 50, 0.30}, {50, 200, 0.25}, {200, null, 0.20}]
model PricingMatrix {
  id         String   @id @default(cuid())
  rooftopId  String   @unique
  tiers      String   @db.Text // JSON
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  rooftop Rooftop @relation(fields: [rooftopId], references: [id], onDelete: Cascade)
}

// ─── Repair Orders ────────────────────────────────────────────────────────────

model RepairOrder {
  id              String   @id @default(cuid())
  rooftopId       String
  advisorId       String
  vin             String
  // Full decoded vehicle snapshot at time of RO creation
  vehicleSnapshot String   @db.Text // JSON
  currentMileage  Int?
  // Human-readable RO number, e.g. "RO-00042" (set at creation from rooftop config)
  roNumber        String?  @unique
  // status: "draft" | "presented" | "approved" | "closed" | "void"
  status          String   @default("draft")
  // Current wizard step: 1-5
  wizardStep      Int      @default(1)
  // Calculated totals (updated on each recalculation)
  partsSubtotal   Float    @default(0)
  laborSubtotal   Float    @default(0)
  shopSupplyFee   Float    @default(0)
  taxAmount       Float    @default(0)
  totalAmount     Float    @default(0)
  notes           String?  @db.Text
  presentedAt     DateTime?
  closedAt        DateTime?
  // DMS sync
  dmsSyncStatus   String?  // "pending" | "synced" | "failed"
  dmsSyncedAt     DateTime?
  dmsExternalId   String?  // RO ID assigned by DMS
  dmsSyncAttempts   Int      @default(0)
  // Scheduling
  scheduledAt       DateTime?          // appointment date/time
  estimatedDuration Int?               // in minutes
  assignedTechId    String?            // FK → User (technician)
  // Customer info
  customerName      String?
  customerPhone     String?
  customerEmail     String?
  // RO type: "customer" | "warranty" | "internal"
  roType            String   @default("customer")
  // vehicleType: "customer" | "lot"
  vehicleType       String   @default("customer")
  // Lot vehicle link (when vehicleType = "lot")
  lotVehicleId      String?
  // Customer profile link
  customerId        String?
  // Fleet account link
  fleetAccountId    String?
  fleetPoNumber     String?  // required PO number for fleet accounts that need it
  // NHTSA recall cache
  openRecallCount   Int?
  recallCheckedAt   DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  rooftop      Rooftop       @relation(fields: [rooftopId], references: [id], onDelete: Cascade)
  advisor      User          @relation(fields: [advisorId], references: [id])
  assignedTech User?         @relation("TechRepairOrders", fields: [assignedTechId], references: [id])
  lineItems    ROLineItem[]
  overrides    ROOverride[]
  auditLogs    AuditLog[]
  messages     ROMessage[]
  roNotes      RONote[]
  // [FEATURE: customer_approval_portal] START
  approvalToken  ROApprovalToken?
  lineDecisions  ROLineItemDecision[]
  // [FEATURE: customer_approval_portal] END
  // [FEATURE: dvi] START
  dviReport      DVIReport?
  // [FEATURE: dvi] END
  // [FEATURE: tech_time_clock] START
  timeEntries    TimeEntry[]
  // [FEATURE: tech_time_clock] END
  // [FEATURE: parts_ordering] START
  partsOrders    PartsOrder[]
  // [FEATURE: parts_ordering] END
  // [FEATURE: core_return_tracking] START
  partReturns    PartReturn[]
  // [FEATURE: core_return_tracking] END
  // [FEATURE: canned_inspections] START
  inspections    RoInspection[]
  // [FEATURE: canned_inspections] END
  partRequests   PartRequest[]
  lotVehicle     LotVehicle?   @relation(fields: [lotVehicleId], references: [id], onDelete: SetNull)
  customer       Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  // [FEATURE: fleet_accounts] START
  fleetAccount   FleetAccount? @relation(fields: [fleetAccountId], references: [id])
  // [FEATURE: fleet_accounts] END
  // [FEATURE: warranty_claims] START
  warrantyClaims WarrantyClaim[]
  // [FEATURE: warranty_claims] END
  // [FEATURE: loaner_vehicles] START
  loanerLoans    LoanerLoan[]
  // [FEATURE: loaner_vehicles] END
  // [FEATURE: special_orders] START
  specialOrders  SpecialOrderPart[]
  // [FEATURE: special_orders] END

  @@index([rooftopId, status])
  @@index([rooftopId, roType])
  @@index([fleetAccountId])
  @@index([advisorId])
  @@index([vin])
  @@index([scheduledAt])
  @@index([assignedTechId])
  @@index([lotVehicleId])
  @@index([customerId])
}

model ROLineItem {
  id             String   @id @default(cuid())
  repairOrderId  String
  // type: "service" | "part" | "labor" | "fee" | "tax"
  type           String
  // source: "recommended" | "otpr" | "manual"
  source         String   @default("recommended")
  serviceId      String?  // links to service definition
  partNumber     String?
  laborOpCode    String?
  supplier       String?  // "NAPA" | "AutoZone" | "O'Reilly" | "Advance" | "RockAuto" | "OEM" | custom
  description    String
  quantity       Float    @default(1)
  unitCost       Float    @default(0) // cost before markup (parts)
  unitPrice      Float    @default(0) // after markup / labor rate applied
  totalPrice     Float    @default(0)
  isAccepted     Boolean  @default(true) // advisor accepted this item
  tags           String   @default("[]") // JSON array of PartTag IDs
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  repairOrder RepairOrder  @relation(fields: [repairOrderId], references: [id], onDelete: Cascade)
  overrides   ROOverride[]
  // [FEATURE: customer_approval_portal] START
  customerDecision ROLineItemDecision?
  // [FEATURE: customer_approval_portal] END
  // [FEATURE: dvi] START
  dviItem      DVIItem?
  // [FEATURE: dvi] END
  // [FEATURE: tech_time_clock] START
  timeEntries  TimeEntry[]
  // [FEATURE: tech_time_clock] END
  // [FEATURE: core_return_tracking] START
  partReturns  PartReturn[]
  // [FEATURE: core_return_tracking] END

  @@index([repairOrderId])
}

// Audit trail for advisor manual overrides
model ROOverride {
  id             String   @id @default(cuid())
  repairOrderId  String
  lineItemId     String?
  advisorId      String
  field          String   // "unitPrice" | "quantity" | "description" | etc.
  oldValue       String?
  newValue       String?
  reason         String?
  createdAt      DateTime @default(now())

  repairOrder RepairOrder @relation(fields: [repairOrderId], references: [id], onDelete: Cascade)
  lineItem    ROLineItem? @relation(fields: [lineItemId], references: [id], onDelete: SetNull)
  advisor     User        @relation(fields: [advisorId], references: [id])

  @@index([repairOrderId])
}

// ─── Document Ingest ──────────────────────────────────────────────────────────

model IngestDocument {
  id            String   @id @default(cuid())
  rooftopId     String
  uploadedById  String
  blobUrl       String
  fileName      String
  mimeType      String
  // "pending" | "done" | "error"
  status        String   @default("pending")
  // JSON: ExtractedData shape
  extractedData String?  @db.Text
  errorMessage  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([rooftopId])
}

// ─── Feature Flags ───────────────────────────────────────────────────────────

// Lightweight feature flag table.
// rooftopId = null → global flag (applies to all rooftops).
// rooftopId set → override for that specific rooftop only.
// Evaluator checks rooftop-level first, falls back to global.
model FeatureFlag {
  id         String   @id @default(cuid())
  flagKey    String   // e.g. "dms_sync", "mfa_enforcement", "tablet_ux"
  rooftopId  String?  // null = global; set = rooftop-level override
  enabled    Boolean  @default(false)
  updatedAt  DateTime @updatedAt

  @@unique([flagKey, rooftopId])
  @@index([flagKey])
}

// ─── Messaging & Announcements ───────────────────────────────────────────────

// Threaded messages and formal notes per Repair Order
// category: "message" (internal chat) | "note" (formal dealer-wide log) | "external" (customer-facing)
model ROMessage {
  id            String      @id @default(cuid())
  repairOrderId String
  authorId      String
  content       String      @db.Text
  category      String      @default("message")
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  repairOrder RepairOrder @relation(fields: [repairOrderId], references: [id], onDelete: Cascade)
  author      User        @relation("UserROMessages", fields: [authorId], references: [id])

  @@index([repairOrderId])
}

// RO Notes — categorized notes separate from team messages.
// category: "customer" | "tech" | "shop" | "concern"
model RONote {
  id            String   @id @default(cuid())
  repairOrderId String
  authorId      String
  content       String   @db.Text
  category      String   @default("shop")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  repairOrder RepairOrder @relation(fields: [repairOrderId], references: [id], onDelete: Cascade)
  author      User        @relation("UserRONotes", fields: [authorId], references: [id])

  @@index([repairOrderId])
}

// Dealer-wide announcements per rooftop
// priority: "info" | "warning" | "urgent"
model Announcement {
  id        String    @id @default(cuid())
  rooftopId String
  authorId  String
  title     String
  body      String    @db.Text
  priority  String    @default("info")
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  rooftop Rooftop @relation(fields: [rooftopId], references: [id], onDelete: Cascade)
  author  User    @relation("UserAnnouncements", fields: [authorId], references: [id])

  @@index([rooftopId])
}

// ─── System ───────────────────────────────────────────────────────────────────

model AuditLog {
  id            String   @id @default(cuid())
  userId        String?
  rooftopId     String?
  repairOrderId String?
  action        String   // e.g. "ro.created", "ro.presented", "rule.updated"
  entityType    String?
  entityId      String?
  diff          String?  @db.Text // JSON
  createdAt     DateTime @default(now())

  user        User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  repairOrder RepairOrder? @relation(fields: [repairOrderId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([rooftopId])
  @@index([createdAt])
}

// ─── Inventory ────────────────────────────────────────────────────────────────

// Per-rooftop parts inventory (warehouse stock, not OEM catalog)
// category: "Filters" | "Fluids" | "Brakes" | "Batteries" | "Belts" | "Ignition" | "Wipers" | "Other"
model PartInventory {
  id             String   @id @default(cuid())
  rooftopId      String
  partNumber     String
  description    String
  category       String   @default("Other")
  supplier       String?
  unitCost       Float    @default(0)
  unitPrice      Float    @default(0)
  quantityOnHand Float    @default(0)
  reorderPoint   Float    @default(5)
  reorderQty     Float    @default(10)
  location       String?  // bin/shelf e.g. "A3-12"
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  rooftop            Rooftop             @relation(fields: [rooftopId], references: [id], onDelete: Cascade)
  movements          InventoryMovement[]
  // [FEATURE: purchase_orders] START
  purchaseOrderLines PurchaseOrderLine[]
  // [FEATURE: purchase_orders] END

  @@unique([rooftopId, partNumber])
  @@index([rooftopId])
  @@index([rooftopId, category])
}

// Audit trail for every stock movement
// type: "receive" | "use" | "adjust" | "return"
// quantity is positive for stock in, negative for stock out
model InventoryMovement {
  id            String   @id @default(cuid())
  inventoryId   String
  type          String
  quantity      Float
  previousQty   Float
  newQty        Float
  reason        String?
  referenceId   String?  // e.g. RO id when type = "use"
  performedById String
  createdAt     DateTime @default(now())

  inventory   PartInventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  performedBy User          @relation(fields: [performedById], references: [id])

  @@index([inventoryId])
  @@index([performedById])
}

// ─── [FEATURE: customer_approval_portal] ─────────────────────────────────────
// Token-based public link for customers to approve/decline RO line items remotely.
// Remove this section and related back-relations on RepairOrder/ROLineItem to disable.

model ROApprovalToken {
  id            String    @id @default(cuid())
  repairOrderId String    @unique
  token         String    @unique @default(cuid())
  expiresAt     DateTime
  usedAt        DateTime?
  createdAt     DateTime  @default(now())

  repairOrder RepairOrder @relation(fields: [repairOrderId], references: [id], onDelete: Cascade)

  @@index([token])
}

model ROLineItemDecision {
  id            String   @id @default(cuid())
  repairOrderId String
  lineItemId    String   @unique
  decision      String   // "approved" | "declined"
  customerName  String?
  // [FEATURE: lost_sales] START
  declineReason String?  // "price" | "time_constraint" | "will_return" | "did_elsewhere" | "other"
  // [FEATURE: lost_sales] END
  decidedAt     DateTime @default(now())

  repairOrder RepairOrder @relation(fields: [repairOrderId], references: [id], onDelete: Cascade)
  lineItem    ROLineItem  @relation(fields: [lineItemId], references: [id], onDelete: Cascade)

  @@index([repairOrderId])
}

// ─── [FEATURE: dvi] ──────────────────────────────────────────────────────────
// Digital Vehicle Inspection — photo/video documentation per RO line item.
// Remove this section and related back-relations on RepairOrder/ROLineItem/User to disable.

model DVIReport {
  id            String   @id @default(cuid())
  repairOrderId String   @unique
  techId        String
  status        String   @default("in_progress") // "in_progress" | "complete"
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  repairOrder RepairOrder @relation(fields: [repairOrderId], references: [id], onDelete: Cascade)
  tech        User        @relation("TechDVIReports", fields: [techId], references: [id])
  items       DVIItem[]
}

model DVIItem {
  id          String   @id @default(cuid())
  reportId    String
  lineItemId  String?  @unique
  label       String
  condition   String   @default("ok") // "ok" | "advisory" | "critical"
  notes       String?  @db.Text
  photoUrls   String   @default("[]") @db.Text // JSON array of Vercel Blob URLs
  videoUrl    String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  report   DVIReport   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  lineItem ROLineItem? @relation(fields: [lineItemId], references: [id], onDelete: SetNull)

  @@index([reportId])
}

// ─── [FEATURE: tech_time_clock] ──────────────────────────────────────────────
// Technician time clock — clock in/out per labor op; tracks actual vs flat-rate hours.
// Remove this section and related back-relations on RepairOrder/ROLineItem/User to disable.

model TimeEntry {
  id            String    @id @default(cuid())
  repairOrderId String
  lineItemId    String?
  techId        String
  clockedInAt   DateTime  @default(now())
  clockedOutAt  DateTime?
  flatRateHours Float?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  repairOrder RepairOrder @relation(fields: [repairOrderId], references: [id], onDelete: Cascade)
  lineItem    ROLineItem? @relation(fields: [lineItemId], references: [id], onDelete: SetNull)
  tech        User        @relation("TechTimeEntries", fields: [techId], references: [id])

  @@index([repairOrderId])
  @@index([techId])
  @@index([clockedInAt])
}

// ─── [FEATURE: parts_ordering] ───────────────────────────────────────────────
// Parts ordering integration — search NAPA/AutoZone and submit orders from within the RO.
// Remove this section and related back-relations on RepairOrder/User to disable.

model PartsOrder {
  id              String    @id @default(cuid())
  repairOrderId   String
  rooftopId       String
  placedById      String
  supplier        String    // "NAPA" | "AutoZone" | "mock"
  externalOrderId String?
  status          String    @default("pending") // "pending"|"submitted"|"confirmed"|"error"
  items           String    @db.Text // JSON: [{ partNumber, description, quantity, unitCost }]
  errorMessage    String?
  submittedAt     DateTime?
  // [FEATURE: backorder_tracking] START
  isBackordered   Boolean   @default(false)
  backorderEta    DateTime?
  // [FEATURE: backorder_tracking] END
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  repairOrder RepairOrder @relation(fields: [repairOrderId], references: [id], onDelete: Cascade)
  placedBy    User        @relation("UserPartsOrders", fields: [placedById], references: [id])

  @@index([repairOrderId])
  @@index([rooftopId])
}

// ─── [FEATURE: core_return_tracking] ─────────────────────────────────────────
// Core/warranty return tracking — track parts returned to supplier for credit recovery.
// Remove this section and related back-relations on Rooftop/RepairOrder/ROLineItem/User to disable.

model PartReturn {
  id             String    @id @default(cuid())
  rooftopId      String
  repairOrderId  String?
  lineItemId     String?
  partNumber     String
  description    String
  supplier       String
  returnType     String    // "core" | "warranty"
  quantity       Float     @default(1)
  expectedCredit Float     @default(0)
  actualCredit   Float?
  status         String    @default("pending") // "pending"|"submitted"|"received"|"credited"|"rejected"
  trackingNumber String?
  notes          String?   @db.Text
  submittedAt    DateTime?
  receivedAt     DateTime?
  creditedAt     DateTime?
  createdById    String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  rooftop     Rooftop      @relation(fields: [rooftopId], references: [id], onDelete: Cascade)
  repairOrder RepairOrder? @relation(fields: [repairOrderId], references: [id], onDelete: SetNull)
  lineItem    ROLineItem?  @relation(fields: [lineItemId], references: [id], onDelete: SetNull)
  createdBy   User         @relation("UserPartReturns", fields: [createdById], references: [id])

  @@index([rooftopId, status])
  @@index([repairOrderId])
}

// ─── [FEATURE: canned_inspections] ───────────────────────────────────────────
// Canned/packaged inspection templates — multi-point checklists auto-attached to ROs.
// Remove this section and related back-relations on RepairOrder/User to disable.

model InspectionTemplate {
  id             String   @id @default(cuid())
  rooftopId      String?  // null = system-wide template available to all rooftops
  name           String
  description    String?
  triggerMileage Int?     // auto-attach when RO mileage is within triggerWindow of this value
  triggerWindow  Int?     @default(2500)
  isActive       Boolean  @default(true)
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  items       InspectionTemplateItem[]
  inspections RoInspection[]
}

model InspectionTemplateItem {
  id         String @id @default(cuid())
  templateId String
  label      String
  // "condition" = ok/advisory/critical toggle
  // "passfail"  = pass/fail toggle
  // "measurement" = numeric value with unit
  checkType  String @default("condition")
  unit       String?
  sortOrder  Int    @default(0)

  template InspectionTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  results  InspectionResult[]

  @@index([templateId])
}

model RoInspection {
  id            String   @id @default(cuid())
  // Nullable — standalone inspections have no RO (repairOrderId = null)
  repairOrderId String?
  templateId    String
  techId        String
  status        String   @default("in_progress") // "in_progress" | "complete"
  // Standalone inspection context (used when repairOrderId = null)
  vin           String?
  vehicleLabel  String?  // e.g. "2018 Ford F-150 XLT"
  lotVehicleId  String?  // link to a lot vehicle instead of RO
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  repairOrder RepairOrder?       @relation(fields: [repairOrderId], references: [id], onDelete: Cascade)
  template    InspectionTemplate @relation(fields: [templateId], references: [id])
  tech        User               @relation("TechInspections", fields: [techId], references: [id])
  lotVehicle  LotVehicle?        @relation(fields: [lotVehicleId], references: [id], onDelete: SetNull)
  results     InspectionResult[]

  @@index([repairOrderId])
  @@index([lotVehicleId])
}

model InspectionResult {
  id             String   @id @default(cuid())
  inspectionId   String
  templateItemId String
  value          String?  // condition/pass-fail string, or numeric measurement as string
  notes          String?
  updatedAt      DateTime @updatedAt

  inspection   RoInspection           @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  templateItem InspectionTemplateItem @relation(fields: [templateItemId], references: [id])

  @@unique([inspectionId, templateItemId])
}

// ─── Part Requests (tech → advisor) ──────────────────────────────────────────
// Techs can flag parts they need on an RO without placing a supplier order.
// Advisors see and manage requests on the Parts Orders tab of the RO.

model PartRequest {
  id              String   @id @default(cuid())
  repairOrderId   String
  rooftopId       String
  requestedById   String
  partDescription String
  partNumber      String?
  quantity        Int      @default(1)
  notes           String?  @db.Text
  // "pending" | "ordered" | "received" | "cancelled"
  status          String   @default("pending")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  repairOrder RepairOrder @relation(fields: [repairOrderId], references: [id], onDelete: Cascade)
  rooftop     Rooftop     @relation(fields: [rooftopId], references: [id])
  requestedBy User        @relation("PartRequestsBy", fields: [requestedById], references: [id])

  @@index([repairOrderId])
  @@index([rooftopId])
}

// ─── [FEATURE: notifications] ────────────────────────────────────────────────
// In-app notification center — bell icon with unread count, role-targeted events.

model Notification {
  id        String    @id @default(cuid())
  rooftopId String
  userId    String
  title     String
  body      String
  // type: "ro_approved"|"parts_arrived"|"dms_sync_failed"|"inspection_flagged"
  //       |"recall_found"|"sop_arrived"|"backorder_cleared"
  type      String
  entityId  String?   // related RO/SOP/return id for navigation
  readAt    DateTime?
  createdAt DateTime  @default(now())

  rooftop Rooftop @relation(fields: [rooftopId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([rooftopId])
}

// ─── [FEATURE: special_orders] ───────────────────────────────────────────────
// Special Order Parts (SOP) — customer-specific parts ordered with deposit tracking.
// status: "ordered" | "received" | "customer_notified" | "picked_up" | "cancelled"

model SpecialOrderPart {
  id               String    @id @default(cuid())
  rooftopId        String
  repairOrderId    String?
  partNumber       String
  description      String
  supplier         String
  quantity         Float     @default(1)
  customerName     String
  customerPhone    String?
  depositCollected Float     @default(0)
  vendorPO         String?
  supplierEta      DateTime?
  status           String    @default("ordered")
  notes            String?   @db.Text
  createdById      String
  arrivedAt        DateTime?
  notifiedAt       DateTime?
  pickedUpAt       DateTime?
  cancelledAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  rooftop     Rooftop      @relation(fields: [rooftopId], references: [id], onDelete: Cascade)
  repairOrder RepairOrder? @relation(fields: [repairOrderId], references: [id], onDelete: SetNull)
  createdBy   User         @relation("SOPCreatedBy", fields: [createdById], references: [id])

  @@index([rooftopId, status])
  @@index([repairOrderId])
}

// ─── [FEATURE: purchase_orders] ──────────────────────────────────────────────
// Purchase Orders for inventory replenishment — create, submit, and receive POs.
// status: "draft" | "submitted" | "partial_received" | "received" | "invoiced"

model PurchaseOrder {
  id          String             @id @default(cuid())
  rooftopId   String
  supplier    String
  status      String             @default("draft")
  notes       String?            @db.Text
  submittedAt DateTime?
  receivedAt  DateTime?
  createdById String
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  rooftop   Rooftop             @relation(fields: [rooftopId], references: [id], onDelete: Cascade)
  createdBy User                @relation("POCreatedBy", fields: [createdById], references: [id])
  lines     PurchaseOrderLine[]

  @@index([rooftopId, status])
}

model PurchaseOrderLine {
  id              String         @id @default(cuid())
  purchaseOrderId String
  partNumber      String
  description     String
  qtyOrdered      Float
  qtyReceived     Float          @default(0)
  unitCost        Float
  inventoryId     String?
  createdAt       DateTime       @default(now())

  purchaseOrder PurchaseOrder  @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  inventory     PartInventory? @relation(fields: [inventoryId], references: [id], onDelete: SetNull)

  @@index([purchaseOrderId])
}

// ─── [FEATURE: warranty_claims] ──────────────────────────────────────────────
// Warranty Claims Tracker — OEM warranty work claim submission and tracking.
// status: "draft" | "submitted" | "approved" | "paid" | "rejected"

model WarrantyClaim {
  id                    String    @id @default(cuid())
  rooftopId             String
  repairOrderId         String
  claimNumber           String?
  failureDescription    String    @db.Text
  oemLaborCode          String?
  partsUsed             String?   @db.Text // JSON: [{ partNumber, description, qty }]
  expectedReimbursement Float     @default(0)
  actualReimbursement   Float?
  status                String    @default("draft")
  rejectionReason       String?   @db.Text
  submittedAt           DateTime?
  approvedAt            DateTime?
  paidAt                DateTime?
  createdById           String
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  rooftop     Rooftop     @relation(fields: [rooftopId], references: [id], onDelete: Cascade)
  repairOrder RepairOrder @relation(fields: [repairOrderId], references: [id], onDelete: Cascade)
  createdBy   User        @relation("WarrantyCreatedBy", fields: [createdById], references: [id])

  @@index([rooftopId, status])
  @@index([repairOrderId])
}

// ─── [FEATURE: loaner_vehicles] ──────────────────────────────────────────────
// Loaner Vehicle Management — track customer loaners during service.
// status: "available" | "loaned" | "in_service"

model LoanerVehicle {
  id           String       @id @default(cuid())
  rooftopId    String
  vin          String
  make         String
  model        String
  year         Int
  licensePlate String?
  color        String?
  status       String       @default("available")
  notes        String?      @db.Text
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  rooftop Rooftop      @relation(fields: [rooftopId], references: [id], onDelete: Cascade)
  loans   LoanerLoan[]

  @@index([rooftopId, status])
}

model LoanerLoan {
  id                String    @id @default(cuid())
  loanerVehicleId   String
  repairOrderId     String
  customerName      String
  customerPhone     String?
  checkOutAt        DateTime  @default(now())
  expectedReturnAt  DateTime?
  checkInAt         DateTime?
  fuelLevelOut      Int       @default(100)
  fuelLevelIn       Int?
  mileageOut        Int
  mileageIn         Int?
  checkOutPhotoUrls String?   @db.Text // JSON array of Vercel Blob URLs
  checkInPhotoUrls  String?   @db.Text
  notes             String?   @db.Text
  createdById       String
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  loanerVehicle LoanerVehicle @relation(fields: [loanerVehicleId], references: [id], onDelete: Cascade)
  repairOrder   RepairOrder   @relation(fields: [repairOrderId], references: [id])
  createdBy     User          @relation("LoanerLoanCreatedBy", fields: [createdById], references: [id])

  @@index([loanerVehicleId])
  @@index([repairOrderId])
}

// ─── Technician Certification Tracker ────────────────────────────────────────
// ASE and OEM certifications per tech with expiry alerts.
// certType: "ASE_A1" | "ASE_A2" | ... | "ASE_L1" | "OEM_FORD" | "OEM_GM" | custom

model TechCertification {
  id         String    @id @default(cuid())
  userId     String
  rooftopId  String
  certType   String
  name       String
  issuedAt   DateTime?
  expiresAt  DateTime?
  certNumber String?
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  rooftop Rooftop @relation(fields: [rooftopId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([rooftopId])
  @@index([expiresAt])
}

// ─── [FEATURE: fleet_accounts] ───────────────────────────────────────────────
// Fleet Account Management — centralized billing for fleet customers.
// billingCycle: "weekly" | "monthly"

model FleetAccount {
  id              String      @id @default(cuid())
  rooftopId       String
  companyName     String
  contactName     String?
  contactPhone    String?
  contactEmail    String?
  billingCycle    String      @default("monthly")
  requiresPo      Boolean     @default(false)
  pricingOverride String?     @db.Text // JSON — same tier structure as PricingMatrix.tiers
  notes           String?     @db.Text
  isActive        Boolean     @default(true)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  rooftop      Rooftop       @relation(fields: [rooftopId], references: [id], onDelete: Cascade)
  repairOrders RepairOrder[]

  @@index([rooftopId, isActive])
}

// ─── Lot Vehicles ─────────────────────────────────────────────────────────────
// Dealer lot vehicles — inventory/fleet cars that can be serviced without a customer RO.
// status: "available" | "in_service" | "sold"

model LotVehicle {
  id           String   @id @default(cuid())
  rooftopId    String
  vin          String?
  year         Int?
  make         String
  model        String
  trim         String?
  color        String?
  licensePlate String?
  stockNumber  String?
  mileage      Int?
  status       String   @default("available")
  notes        String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  rooftop      Rooftop        @relation(fields: [rooftopId], references: [id], onDelete: Cascade)
  repairOrders RepairOrder[]
  inspections  RoInspection[]

  @@index([rooftopId, status])
}

// ─── Customers ────────────────────────────────────────────────────────────────
// Persistent customer profiles. Denormalized customer fields on RepairOrder are
// kept for backward compatibility; this model enables a proper customer module.

model Customer {
  id        String   @id @default(cuid())
  rooftopId String
  name      String
  phone     String?
  email     String?
  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rooftop      Rooftop           @relation(fields: [rooftopId], references: [id], onDelete: Cascade)
  repairOrders RepairOrder[]
  vehicles     CustomerVehicle[]

  @@index([rooftopId])
  @@index([phone])
}

model CustomerVehicle {
  id           String   @id @default(cuid())
  customerId   String
  rooftopId    String
  vin          String?
  year         Int?
  make         String
  model        String
  trim         String?
  color        String?
  licensePlate String?
  mileage      Int?
  notes        String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  rooftop  Rooftop  @relation(fields: [rooftopId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([rooftopId])
  @@index([vin])
}

// ─── Part Tags ────────────────────────────────────────────────────────────────
// User-defined tags for RO line items (e.g. "NAPA", "Backordered", "Special Order").
// ROLineItem.tags stores a JSON array of PartTag IDs.

model PartTag {
  id        String   @id @default(cuid())
  rooftopId String
  name      String
  color     String   @default("#6b7280")
  createdAt DateTime @default(now())

  rooftop Rooftop @relation(fields: [rooftopId], references: [id], onDelete: Cascade)

  @@unique([rooftopId, name])
  @@index([rooftopId])
}
